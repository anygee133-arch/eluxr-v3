      "name": "Initial Wait",
      "type": "n8n-nodes-base.wait",
      "position": [1320, 300],
      "typeVersion": 1.1,
      "webhookId": "img-initial-wait-webhook"
    },
    {
      "parameters": {
        "url": "=https://api.kie.ai/api/v1/jobs/recordInfo?taskId={{ $json.data?.taskId || $json.taskId }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth"
      },
      "id": "img-kie-get-001",
      "name": "KIE \u2014 Get Image Result",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1540, 300],
      "typeVersion": 4.2,
      "credentials": {
        "httpHeaderAuth": {
          "id": "KIE_AI_API_CREDENTIAL",
          "name": "KIE AI API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const result = $input.item.json;\nconst pollCount = (result.pollCount || 0) + 1;\n\nconst state = result.data?.state || result.state || 'processing';\nconst isReady = state === 'success' || state === 'completed';\nconst isTimeout = pollCount >= 12;\nconst isError = state === 'failed' || state === 'error';\n\nreturn {\n  json: {\n    ...result,\n    pollCount,\n    isComplete: isReady || isTimeout || isError,\n    isSuccess: isReady,\n    error: isTimeout ? 'Image generation timed out after 65 seconds' :\n           isError ? `Image generation failed: ${state}` : null\n  }\n};"
      },
      "id": "img-check-result-001",
      "name": "Check Image Result",
      "type": "n8n-nodes-base.code",
      "position": [1760, 300],
      "typeVersion": 2
    },
