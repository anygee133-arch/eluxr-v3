      "id": "img-if-success-001",
      "name": "Is Success?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2200, 200]
    },
    {
      "parameters": {
        "jsCode": "const result = $input.item.json;\n\nlet imageUrl = '';\n\nif (result.data && result.data.resultJson) {\n  try {\n    const parsed = JSON.parse(result.data.resultJson);\n    if (parsed.resultUrls && parsed.resultUrls.length > 0) {\n      imageUrl = parsed.resultUrls[0];\n    }\n  } catch(e) {\n    // fallback\n  }\n}\n\nreturn {\n  json: {\n    success: !!imageUrl,\n    image_url: imageUrl,\n    taskId: result.data?.taskId || result.taskId || ''\n  }\n};"
      },
