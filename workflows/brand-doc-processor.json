    {
      "id": "bd-0090",
      "name": "Format PDF Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1940,
        100
      ],
      "parameters": {
        "jsCode": "// Concatenate all text from PDF extraction\nconst items = $input.all();\nlet text = '';\nfor (const item of items) {\n  const json = item.json;\n  if (json.text) {\n    text += json.text + '\\n';\n  } else {\n    for (const [key, val] of Object.entries(json)) {\n      if (typeof val === 'string' && val.trim()) {\n        text += val + '\\n';\n      }\n    }\n  }\n}\n\nreturn [{ json: { extracted_text: text.trim() } }];"
      }
    },
    {
      "id": "bd-0100",
      "name": "Read as Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1720,
        350
      ],
      "parameters": {
        "jsCode": "const params = $('Extract Params').first().json;\nconst ext = params.file_extension;\n\n// DOCX files are ZIP archives - can't parse in n8n sandbox\nif (ext === 'docx' || ext === 'doc') {\n  return [{ json: {\n    extracted_text: '[DOCX format - cannot extract text automatically]',\n    is_docx: true\n  }}];\n}\n\n// TXT files - read binary as UTF-8\nconst binary = $input.item.binary;\nif (binary && binary.data) {\n  const buffer = Buffer.from(binary.data.data, 'base64');\n  return [{ json: { extracted_text: buffer.toString('utf-8') } }];\n}\n\nreturn [{ json: { extracted_text: '' } }];"
      }
    },
    {
      "id": "bd-0110",
      "name": "Build Claude Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        200
      ],
      "parameters": {
        "jsCode": "const params = $('Extract Params').first().json;\nconst inputData = $input.first().json;\nlet extractedText = (inputData.extracted_text || '').substring(0, 30000);\n\n// Handle DOCX or empty files - skip AI\nif (inputData.is_docx || extractedText.trim().length < 20) {\n  const fallbackMsg = inputData.is_docx\n    ? 'This document is in DOCX format which cannot be automatically processed. Please re-upload as PDF or TXT for brand voice analysis.'\n    : 'Unable to extract sufficient text from this document. Please upload a text-based PDF or TXT file.';\n  \n  return [{ json: {\n    document_id: params.document_id,\n    user_id: params.user_id,\n    extracted_text: extractedText || '[empty]',\n    summary_text: fallbackMsg,\n    skip_ai: true\n  }}];\n}\n\nconst apiBody = JSON.stringify({\n  model: 'claude-sonnet-4-20250514',\n  max_tokens: 1024,\n  messages: [{\n    role: 'user',\n    content: 'Analyze the following brand document and produce a structured brand voice profile. Extract the key elements that would guide a social media content writer.\\n\\nDOCUMENT TEXT:\\n' + extractedText + '\\n\\nReturn a structured profile in this exact format (keep total under 2000 characters):\\n\\nBRAND VOICE PROFILE:\\n- Voice & Tone: [2-4 descriptive words about the brand\\'s communication style]\\n- Key Messages: [2-3 core value propositions or positioning statements]\\n- Language Do\\'s: [specific words, phrases, or style choices the brand prefers]\\n- Language Don\\'ts: [words, phrases, or tonal approaches to avoid]\\n- Brand Personality: [1-2 sentences describing how the brand would speak if it were a person]\\n\\nBe specific and actionable. Extract real examples from the document where possible. Do not be generic.'\n  }]\n});\n\nreturn [{ json: {\n  document_id: params.document_id,\n  user_id: params.user_id,\n  extracted_text: extractedText,\n  apiBody: apiBody,\n  skip_ai: false\n}}];"
      }
    },
