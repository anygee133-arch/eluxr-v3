            }
          },
          "timeout": 120000
        }
      },
      "credentials": {
        "anthropicApi": {
          "id": "cZwkXj4ZfHTkpBtT",
          "name": "Anthropic account"
        }
      },
      "alwaysOutputData": true
    },
    {
      "id": "bd-0140",
      "name": "Parse Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2820,
        350
      ],
      "parameters": {
        "jsCode": "const params = $('Build Claude Prompt').first().json;\nconst claudeResponse = $input.first().json;\n\nlet summaryText = '';\ntry {\n  summaryText = claudeResponse.content[0].text || '';\n} catch(e) {\n  summaryText = 'Error processing document. Please try uploading again.';\n}\n\nreturn [{ json: {\n  document_id: params.document_id,\n  extracted_text: params.extracted_text,\n  summary_text: summaryText.substring(0, 2000)\n}}];"
      }
    },
