    {
      "id": "bd-0050",
      "name": "Extract Params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1060,
        200
      ],
      "parameters": {
        "jsCode": "const authData = $input.item.json;\nconst body = authData.body || {};\nconst fileUrl = body.file_url || '';\nconst urlParts = fileUrl.split('/');\nconst rawName = urlParts[urlParts.length - 1] || '';\nconst cleanName = rawName.split('?')[0];\nconst ext = cleanName.split('.').pop().toLowerCase();\n\n// Build authenticated download URL\nlet downloadUrl = fileUrl;\nif (fileUrl.includes('/storage/v1/object/public/')) {\n  downloadUrl = fileUrl.replace('/storage/v1/object/public/', '/storage/v1/object/');\n}\n\nreturn {\n  json: {\n    document_id: body.document_id || '',\n    file_url: fileUrl,\n    download_url: downloadUrl,\n    user_id: authData.user_id || body.user_id || '',\n    file_extension: ext,\n    file_name: decodeURIComponent(cleanName)\n  }\n};"
      }
    },
    {
