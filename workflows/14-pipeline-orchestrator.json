    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst pipelineRunId = body.pipeline_run_id;\nconst completedStep = body.step;\nconst status = body.status || 'complete';\nconst errorMessage = body.error_message || '';\nconst data = body.data || {};\n\n// Recover auth token and context from pipeline_runs metadata\n// (stored during Create Pipeline Run)\nconst authToken = body.auth_token || data.auth_token || '';\nconst context = data.context || {};\n\n// Define pipeline stages: what to fire AFTER each step completes\nconst stages = {\n  1: { step: 2, label: 'Creating content themes...', webhook: 'eluxr-phase2-themes', week_number: null },\n  2: { step: 3, label: 'Generating Week 1 content...', webhook: 'eluxr-phase4-studio', week_number: 1 },\n  3: { step: 4, label: 'Generating Week 2 content...', webhook: 'eluxr-phase4-studio', week_number: 2 },\n  4: { step: 5, label: 'Generating Week 3 content...', webhook: 'eluxr-phase4-studio', week_number: 3 },\n  5: { step: 6, label: 'Generating Week 4 content...', webhook: 'eluxr-phase4-studio', week_number: 4 },\n  6: { step: null, label: 'Complete!', webhook: null, week_number: null }\n};\n\n// Handle error status from sub-workflow\nif (status === 'error') {\n  return {\n    json: {\n      action: 'mark_failed',\n      pipeline_run_id: pipelineRunId,\n      completed_step: completedStep,\n      error_message: errorMessage\n    }\n  };\n}\n\nconst nextStage = stages[completedStep];\nif (!nextStage) {\n  return {\n    json: {\n      action: 'mark_failed',\n      pipeline_run_id: pipelineRunId,\n      completed_step: completedStep,\n      error_message: 'Unknown step: ' + completedStep\n    }\n  };\n}\n\nif (nextStage.step === null) {\n  // Pipeline complete (step 6 finished)\n  return {\n    json: {\n      action: 'mark_complete',\n      pipeline_run_id: pipelineRunId,\n      completed_step: completedStep\n    }\n  };\n}\n\n// Fire next stage\nreturn {\n  json: {\n    action: 'fire_next',\n    pipeline_run_id: pipelineRunId,\n    completed_step: completedStep,\n    next_step: nextStage.step,\n    step_label: nextStage.label,\n    webhook_path: nextStage.webhook,\n    week_number: nextStage.week_number,\n    auth_token: authToken,\n    context: context\n  }\n};"
      },
