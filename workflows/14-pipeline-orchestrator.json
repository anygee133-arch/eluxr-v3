      "parameters": {
        "jsCode": "// Reference Auth Validator output by name (HTTP Request replaced $json)\nconst authData = $('Auth Validator').item.json;\nconst userId = authData.user_id;\nconst email = authData.email || '';\nconst body = authData.body || {};\n\n// Capture the original Authorization header for passing to sub-workflows\nconst webhookData = $('Webhook').item.json;\nconst authHeader = (webhookData.headers || {}).authorization || (webhookData.headers || {}).Authorization || '';\n\nreturn {\n  json: {\n    user_id: userId,\n    pipeline_type: 'full_pipeline',\n    status: 'running',\n    current_step: 0,\n    total_steps: 6,\n    step_label: 'Starting...',\n    step_progress: 0,\n    started_at: new Date().toISOString(),\n    metadata: {\n      business_url: body.business_url || '',\n      industry: body.industry || '',\n      month: body.month || new Date().toISOString().slice(0, 7),\n      products: body.products || '',\n      brand_voice: body.brand_voice || '',\n      platforms: (body.platforms && body.platforms.length > 0) ? body.platforms : ['linkedin', 'instagram', 'x', 'youtube'],\n      auth_token: authHeader\n    },\n    body: body,\n    email: email,\n    auth_header: authHeader\n  }\n};"
      },
