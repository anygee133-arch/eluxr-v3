        "jsonBody": "={{ JSON.stringify({ user_id: $json.user_id, pipeline_type: $json.pipeline_type, status: $json.status, current_step: $json.current_step, total_steps: $json.total_steps, step_label: $json.step_label, step_progress: $json.step_progress, started_at: $json.started_at, metadata: $json.metadata }) }}",
        "options": {}
