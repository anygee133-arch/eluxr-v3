    {
      "parameters": {
        "jsCode": "// Recover pipeline_run_id from Route Next Stage (callback body), NOT from PATCH response\n// PATCH response has 'id' field, not 'pipeline_run_id' \u2014 this was causing undefined propagation\nconst routeData = $('Route Next Stage').item.json;\nconst runId = routeData.pipeline_run_id;\nconst nextStep = routeData.next_step;\nconst webhookPath = routeData.webhook_path;\nconst weekNumber = routeData.week_number;\nconst authToken = routeData.auth_token;\nconst context = routeData.context || {};\n\n// Get pipeline_runs row to recover metadata\nconst patchResult = $input.item.json;\nconst row = Array.isArray(patchResult) ? patchResult[0] : patchResult;\nconst metadata = row.metadata || {};\n\nreturn {\n  json: {\n    webhook_url: 'https://flowbound.app.n8n.cloud/webhook/' + webhookPath,\n    fire_body: {\n      pipeline_run_id: runId,\n      callback_url: 'https://flowbound.app.n8n.cloud/webhook/eluxr-pipeline-callback',\n      user_id: row.user_id || metadata.user_id || '',\n      business_url: metadata.business_url || context.business_url || '',\n      industry: metadata.industry || context.industry || '',\n      month: metadata.month || context.month || new Date().toISOString().slice(0, 7),\n      platforms: (metadata.platforms && metadata.platforms.length > 0) ? metadata.platforms : (context.platforms && context.platforms.length > 0) ? context.platforms : ['linkedin', 'instagram', 'x', 'youtube'],\n      brand_voice: metadata.brand_voice || context.brand_voice || '',\n      week_number: weekNumber\n    },\n    auth_token: authToken || metadata.auth_token || ''\n  }\n};"
      },
      "id": "orch-0001-4000-8000-000000000036",
