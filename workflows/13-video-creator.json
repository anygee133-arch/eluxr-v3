            "response": {
              "neverError": true
            }
          }
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth"
      },
      "id": "vg-kie-get-001",
      "name": "KIE \u2014 Get Video Status",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1320, 300],
      "typeVersion": 4.2,
      "retryOnFail": true,
      "credentials": {
        "httpHeaderAuth": {
          "id": "KIE_AI_API_CREDENTIAL",
          "name": "KIE AI API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "video-success-check",
              "leftValue": "={{ $json.data.successFlag }}",
              "rightValue": "1",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "id": "vg-if-ready-001",
      "name": "Video Ready?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1540, 300]
    },
    {
      "parameters": {
        "jsCode": "const result = $input.item.json;\n\nlet videoUrl = '';\n\nif (result.data && result.data.resultJson) {\n  try {\n    const parsed = JSON.parse(result.data.resultJson);\n    if (parsed.resultUrls && parsed.resultUrls.length > 0) {\n      videoUrl = parsed.resultUrls[0];\n    }\n  } catch(e) {}\n}\n\nreturn {\n  json: {\n    success: !!videoUrl,\n    video_url: videoUrl,\n    taskId: result.data?.taskId || result.taskId || ''\n  }\n};"
      },
      "id": "vg-parse-result-001",
      "name": "Parse Video Result",
      "type": "n8n-nodes-base.code",
      "position": [1760, 200],
      "typeVersion": 2
    },
    {
      "parameters": {
