      "id": "15-top-0500",
      "name": "Claude Generate Topics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, -200],
      "credentials": {
        "anthropicApi": {
          "id": "cZwkXj4ZfHTkpBtT",
          "name": "Anthropic account"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst prepData = $('Prepare Claude Prompt').item.json;\n\nlet raw = '';\ntry {\n  raw = input.content[0].text;\n} catch(e) { raw = '[]'; }\n\nlet topics = [];\ntry {\n  topics = JSON.parse(raw);\n} catch(e) {\n  const stripped = raw.replace(/```(?:json)?\\s*/g, '').replace(/```\\s*$/g, '').trim();\n  try { topics = JSON.parse(stripped); } catch(e2) {\n    const match = stripped.match(/\\[[\\s\\S]*\\]/);\n    if (match) { try { topics = JSON.parse(match[0]); } catch(e3) { topics = []; } }\n  }\n}\n\nif (!Array.isArray(topics)) topics = [];\n\n// Map product_name to product_id\nconst products = prepData.products || [];\nconst mapped = topics.slice(0, 7).map((t, i) => {\n  let productId = null;\n  let productName = t.product_name || null;\n  if (productName) {\n    const match = products.find(p => p.name.toLowerCase() === productName.toLowerCase());\n    if (match) productId = match.id;\n  }\n  return {\n    user_id: prepData.user_id,\n    campaign_id: prepData.campaign_id,\n    week_number: prepData.week_number,\n    day_number: t.day_number || (i + 1),\n    topic: (t.topic || 'Topic ' + (i + 1)).substring(0, 255),\n    description: (t.description || '').substring(0, 500),\n    content_angle: (t.content_angle || 'General').substring(0, 100),\n    product_id: productId,\n    product_name: productName,\n    status: 'pending'\n  };\n});\n\nreturn {\n  json: {\n    topics: mapped,\n    topics_body: JSON.stringify(mapped),\n    user_id: prepData.user_id,\n    campaign_id: prepData.campaign_id,\n    week_number: prepData.week_number\n  }\n};"
      },
