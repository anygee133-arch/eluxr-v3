    {
      "parameters": {
        "jsCode": "const params = $('Extract Params').item.json;\nconst icpRaw = $('Read ICP').item.json;\nconst productsRaw = $('Read Products').item.json;\n\n// Parse ICP\nlet icp = {};\ntry {\n  icp = Array.isArray(icpRaw) ? icpRaw[0] || {} : icpRaw || {};\n} catch(e) { icp = {}; }\n\n// Parse products\nlet products = [];\ntry {\n  products = Array.isArray(productsRaw) ? productsRaw : [];\n} catch(e) { products = []; }\n\nconst productsList = products.map(p => p.name + ' (' + (p.category || 'General') + '): ' + (p.description || '')).join('\\n');\n\nconst weekNum = params.week_number;\nconst dayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];\n\nconst body = JSON.stringify({\n  model: 'claude-sonnet-4-20250514',\n  max_tokens: 4096,\n  system: 'You are a social media content strategist. Generate engaging daily topics for a weekly content calendar.',\n  messages: [{\n    role: 'user',\n    content: 'Generate 7 daily social media content topics for WEEK ' + weekNum + ' of a monthly campaign.\\n\\nBUSINESS CONTEXT:\\n- Industry: ' + (icp.industry || 'General') + '\\n- Target Audience: ' + (icp.target_audience || icp.demographics || 'General audience') + '\\n- Brand Voice: ' + (icp.brand_voice || icp.tone || 'Professional and engaging') + '\\n- Content Pillars: ' + JSON.stringify(icp.content_pillars || []) + '\\n- Pain Points: ' + JSON.stringify(icp.pain_points || []) + '\\n\\nPRODUCTS/SERVICES:\\n' + (productsList || 'No specific products listed') + '\\n\\nFor each of the 7 days (' + dayNames.join(', ') + '), provide:\\n1. topic: A compelling topic title (max 60 chars)\\n2. description: Brief description of the post angle (max 150 chars)\\n3. content_angle: The content format/approach (e.g., \"Educational Tip\", \"Behind the Scenes\", \"Customer Story\", \"Product Spotlight\", \"Industry Insight\", \"Engagement Post\", \"Weekend Inspiration\")\\n4. product_name: Name of a relevant product/service to feature (or null if not product-focused)\\n\\nMake topics diverse across content types. Week ' + weekNum + ' should feel fresh and distinct.\\n\\nReturn ONLY a valid JSON array of 7 objects with keys: day_number (1-7), topic, description, content_angle, product_name. No markdown.'\n  }]\n});\n\nreturn {\n  json: {\n    apiBody: body,\n    user_id: params.user_id,\n    campaign_id: params.campaign_id,\n    week_number: weekNum,\n    products: products\n  }\n};"
      },
