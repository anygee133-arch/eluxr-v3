{
  "name": "ELUXR Auth Validator",
  "nodes": [
    {
      "parameters": {},
      "id": "a1b2c3d4-0001-4000-8000-000000000001",
      "name": "Sub-Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst query = $input.item.json.query || {};\n\n// Check for internal pipeline secret first (inter-service calls)\nconst pipelineSecret = headers['x-pipeline-secret'] || headers['X-Pipeline-Secret'] || '';\nif (pipelineSecret === 'eluxr-pipeline-internal-2024' && body.user_id) {\n  return { json: { internal: true, user_id: body.user_id, body: body, query: query } };\n}\n\nconst authHeader = headers.authorization || headers.Authorization || '';\n\nif (!authHeader.startsWith('Bearer ')) {\n  return { json: { authenticated: false, error: 'Missing or invalid Authorization header', statusCode: 401 } };\n}\n\nconst token = authHeader.replace('Bearer ', '');\nreturn { json: { internal: false, token: token, body: body, query: query } };"
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000002",
      "name": "Extract Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-internal-check",
              "leftValue": "={{ $json.internal }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000010",
      "name": "Is Internal?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [440, 0]
    },
    {
      "parameters": {
        "jsCode": "// Trusted internal call - pipeline secret verified\nconst data = $input.item.json;\nreturn { json: {\n  authenticated: true,\n  user_id: data.user_id,\n  email: '',\n  role: 'authenticated',\n  body: data.body || {},\n  query: data.query || {}\n} };"
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000011",
      "name": "Internal Auth Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
