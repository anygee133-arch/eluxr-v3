    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://llpnwaoxisfwptxvdfed.supabase.co/auth/v1/user",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.token }}"
            },
            {
              "name": "apikey",
              "value": "sb_publishable_9gnLO_J9HBxVta1f8Ecvxw_KO8huPYQ"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000004",
      "name": "Validate via Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 0]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\n\nif (response.error || response.msg || !response.id) {\n  const errorMsg = response.error_description || response.error || response.msg || 'JWT validation failed';\n  return { json: { authenticated: false, error: errorMsg, statusCode: 401 } };\n}\n\nconst extractTokenData = $('Extract Token').item.json;\nreturn { json: {\n  authenticated: true,\n  user_id: response.id,\n  email: response.email || '',\n  role: response.role || '',\n  body: extractTokenData.body || {},\n  query: extractTokenData.query || {}\n} };"
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000005",
      "name": "Extract User Identity",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 0]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nreturn { json: {\n  authenticated: false,\n  error: input.error || 'JWT validation failed',\n  statusCode: 401\n} };"
      },
