      "parameters": {
        "jsCode": "const params = $('Extract Params').item.json;\nconst jinaResponse = $input.item.json;\n\nlet pageContent = '';\nif (typeof jinaResponse === 'string') {\n  pageContent = jinaResponse;\n} else if (jinaResponse.data) {\n  pageContent = typeof jinaResponse.data === 'string' ? jinaResponse.data : JSON.stringify(jinaResponse.data);\n} else if (jinaResponse.body) {\n  pageContent = jinaResponse.body;\n} else {\n  pageContent = JSON.stringify(jinaResponse);\n}\n\n// Truncate to 3000 chars to keep Claude prompt reasonable\npageContent = pageContent.substring(0, 3000);\n\nconst prompt = `Extract product information from this webpage content. Return JSON only:\\n{\\n  \"name\": \"product name\",\\n  \"description\": \"short product description (max 200 chars)\",\\n  \"image_url\": \"main product image URL or null\",\\n  \"image_urls\": [\"all product image URLs found\"],\\n  \"price\": \"price string or null\",\\n  \"category\": \"product category\"\\n}\\n\\nWebpage content:\\n${pageContent}`;\n\nconst apiBody = {\n  model: 'claude-haiku-4-5-20251001',\n  max_tokens: 1024,\n  messages: [{ role: 'user', content: prompt }]\n};\n\nreturn {\n  json: {\n    apiBody: JSON.stringify(apiBody),\n    product_id: params.product_id,\n    user_id: params.user_id\n  }\n};"
      },
