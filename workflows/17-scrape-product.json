      "parameters": {
        "jsCode": "const params = $('Extract Params').item.json;\nconst claudeResponse = $input.item.json;\n\nlet raw = '';\nif (claudeResponse.content && claudeResponse.content[0]) {\n  raw = claudeResponse.content[0].text;\n} else if (typeof claudeResponse === 'string') {\n  raw = claudeResponse;\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch(e) {\n  const stripped = raw.replace(/```(?:json)?\\s*/g, '').replace(/```\\s*$/g, '').trim();\n  try {\n    parsed = JSON.parse(stripped);\n  } catch(e2) {\n    const match = stripped.match(/[\\[{][\\s\\S]*[\\]}]/);\n    if (match) {\n      try { parsed = JSON.parse(match[0]); } catch(e3) { parsed = {}; }\n    } else {\n      parsed = {};\n    }\n  }\n}\n\nreturn {\n  json: {\n    product_id: params.product_id,\n    name: parsed.name || null,\n    description: parsed.description || null,\n    image_url: parsed.image_url || null,\n    image_urls: parsed.image_urls || [],\n    price: parsed.price || null,\n    category: parsed.category || null\n  }\n};"
      },
