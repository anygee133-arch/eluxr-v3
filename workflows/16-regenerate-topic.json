    {
      "parameters": {
        "jsCode": "const currentTopic = $('Parse Current Topic').item.json;\nconst siblingsRaw = $('Read Sibling Topics').item.json;\nconst icpRaw = $('Read ICP').item.json;\n\nlet siblings = [];\ntry { siblings = Array.isArray(siblingsRaw) ? siblingsRaw : []; } catch(e) { siblings = []; }\n\nlet icp = {};\ntry { icp = Array.isArray(icpRaw) ? icpRaw[0] || {} : icpRaw || {}; } catch(e) { icp = {}; }\n\nconst siblingTopics = siblings.map(s => s.topic + ' (' + s.content_angle + ')').join(', ');\n\nconst dayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];\nconst dayName = dayNames[(currentTopic.day_number || 1) - 1] || 'Day ' + currentTopic.day_number;\n\nconst body = JSON.stringify({\n  model: 'claude-sonnet-4-20250514',\n  max_tokens: 1024,\n  system: 'You are a social media content strategist. Generate a replacement topic that is different from existing topics.',\n  messages: [{\n    role: 'user',\n    content: 'Generate 1 NEW replacement topic for ' + dayName + ' (Day ' + currentTopic.day_number + ') of Week ' + currentTopic.week_number + '.\\n\\nCURRENT TOPIC TO REPLACE: ' + currentTopic.topic + '\\n\\nOTHER TOPICS THIS WEEK (avoid duplicating): ' + (siblingTopics || 'none') + '\\n\\nBUSINESS CONTEXT:\\n- Industry: ' + (icp.industry || 'General') + '\\n- Target Audience: ' + (icp.target_audience || 'General audience') + '\\n- Content Pillars: ' + JSON.stringify(icp.content_pillars || []) + '\\n\\nReturn ONLY a single JSON object with keys: topic, description, content_angle, product_name. Must be completely different from the current topic and siblings. No markdown.'\n  }]\n});\n\nreturn {\n  json: {\n    apiBody: body,\n    topic_id: currentTopic.topic_id || currentTopic.id,\n    user_id: currentTopic.user_id,\n    campaign_id: currentTopic.campaign_id,\n    week_number: currentTopic.week_number,\n    day_number: currentTopic.day_number\n  }\n};"
      },
