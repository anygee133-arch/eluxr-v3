    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst prepData = $('Prepare Claude Prompt').item.json;\n\nlet raw = '';\ntry { raw = input.content[0].text; } catch(e) { raw = '{}'; }\n\nlet newTopic = {};\ntry {\n  newTopic = JSON.parse(raw);\n} catch(e) {\n  const stripped = raw.replace(/```(?:json)?\\s*/g, '').replace(/```\\s*$/g, '').trim();\n  try { newTopic = JSON.parse(stripped); } catch(e2) { newTopic = {}; }\n}\n\nconst updateBody = JSON.stringify({\n  topic: (newTopic.topic || 'New Topic').substring(0, 255),\n  description: (newTopic.description || '').substring(0, 500),\n  content_angle: (newTopic.content_angle || 'General').substring(0, 100),\n  product_name: newTopic.product_name || null,\n  status: 'pending',\n  updated_at: new Date().toISOString()\n});\n\nreturn {\n  json: {\n    updateBody: updateBody,\n    topic_id: prepData.topic_id,\n    newTopic: newTopic\n  }\n};"
      },
